{
  "template": "single-stock",
  "title": "贵州茅台 · 个股画像",
  "subtitle": "请在生成前替换为基于真实数据的一句话结论。",
  "package_id": "pkg_replace_after_formula_package_register",
  "out_file": "output/pages/single-stock-factsheet.html",
  "upload": false,
  "ttl_days": 365,
  "page_type": "个股画像",
  "panels": [
    {
      "title": "阅读摘要",
      "type": "text",
      "span": "full",
      "text": "请在生成前替换为 2-3 句基于真实数据的摘要：价格位置、涨跌幅、估值、成交活跃度，以及本页未覆盖的风险口径。"
    },
    {
      "title": "最新收盘价",
      "output": "px",
      "type": "number",
      "description": "价格序列末个有效值",
      "unit": "元"
    },
    {
      "title": "日涨跌幅",
      "output": "chg",
      "type": "number",
      "unit": "%",
      "description": "最近交易日"
    },
    {
      "title": "20日表现",
      "output": "ret20",
      "type": "number",
      "unit": "%",
      "description": "短期动量"
    },
    {
      "title": "60日表现",
      "output": "ret60",
      "type": "number",
      "unit": "%",
      "description": "中期动量"
    },
    {
      "title": "市盈率 TTM",
      "output": "pe",
      "type": "number",
      "description": "滚动 12 个月"
    },
    {
      "title": "市净率 PB",
      "output": "pb",
      "type": "number",
      "description": "最新可得估值"
    },
    {
      "title": "成交额",
      "output": "amt_yi",
      "type": "number",
      "unit": "亿元",
      "description": "最近交易日"
    },
    {
      "title": "近一年收盘价",
      "output": "px",
      "type": "line",
      "span": "full",
      "height": 380,
      "description": "主图占整行，作为画像页的视觉中心。"
    }
  ]
}
